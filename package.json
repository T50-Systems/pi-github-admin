{
  "name": "pi-github-admin",
  "version": "0.3.0",
  "description": "Pi-native GitHub admin tools for repos, metadata, branch protection, issues, milestones, labels, and releases.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "github",
    "automation"
  ],
  "pi": {
    "extensions": [
      "./extensions/index.ts"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "files": [
